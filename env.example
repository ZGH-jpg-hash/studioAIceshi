# OpenAI兼容协议LLM配置模板

# API基础URL
# 例如: http://localhost:1234 （LM Studio本地服务器）
BASE_URL=http://localhost:1234

# 模型名称
# 例如: google/gemma-3-4b （LM Studio模型标识符）
MODEL=google/gemma-3-4b

# API密钥
# 例如: sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
API_KEY=your_api_key_here

# 温度参数 (0.0-2.0)
TEMPERATURE=0.7

# 最大令牌数
MAX_TOKENS=1000

# 超时设置（秒）
TIMEOUT=30
